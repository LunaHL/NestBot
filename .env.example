# === Discord Bot ===
DISCORD_TOKEN=             # Your bot token (from Developer Portal -> Bot -> Token)
DISCORD_CLIENT_ID=         # Your Application (Client) ID
DISCORD_GUILD_ID=          # Dev server ID (optional, speeds up command registration)

# === Runtime ===
NODE_ENV=production        # "development" for testing, "production" for live
TZ=Europe/Berlin           # Timezone, needed for cron jobs (birthdays, etc.)
LOG_LEVEL=info             # "debug", "info", "warn", "error"

# === Dashboard (optional web server) ===
DASHBOARD_PORT=3210        # Local port for the web dashboard
DASHBOARD_HOST=0.0.0.0     # 0.0.0.0 to expose to LAN, 127.0.0.1 for local only
DASHBOARD_TOKEN=           # Secret for protecting the dashboard API
